<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ai-brain.sync-youtube-cookies</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/tagishitakuya/Desktop/ClaudeProjects/AI-Brain/Shared/Workflows/sync-youtube-cookies.sh</string>
    </array>

    <!-- 毎週月曜 午前3時に実行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/ai-brain-sync-youtube-cookies.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/ai-brain-sync-youtube-cookies.err</string>
</dict>
</plist>
