<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ai-brain.queue-processor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-l</string>
        <string>-c</string>
        <string>source ~/.zshrc 2>/dev/null; cd /Users/tagishitakuya/Desktop/ClaudeProjects/AI-Brain &amp;&amp; /usr/bin/python3 Projects/dmm-manga-affiliate/Workflows/queue-processor.py</string>
    </array>

    <!-- 2分おき（120秒）-->
    <key>StartInterval</key>
    <integer>120</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/ai-brain-queue-processor.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/ai-brain-queue-processor.err</string>
</dict>
</plist>
